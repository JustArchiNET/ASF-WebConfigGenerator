{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",

	"extends": [
		"config:best-practices",
		":automergeBranch",
		":automergeDigest",
		":automergeMinor",
		":disableDependencyDashboard",
		":disableRateLimiting",
		":label(🤖 Automatic)",
		":reviewer(Aareksio)"
	],

	"packageRules": [
		{
			"matchManagers": [ "github-actions" ],
			"reviewers": [ "JustArchi" ]
		}
	]
}
